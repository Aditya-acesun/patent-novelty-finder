# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
AI_SERVICE_URL=http://ai-service:8000

# ─── MongoDB Atlas ─────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/patent_finder?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Qdrant ────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=patents

# ─── Redis (Celery broker) ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM (for RAG report generation) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OR use OpenAI:
# OPENAI_API_KEY=sk-...

# ─── Frontend ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api
VITE_AI_SERVICE_URL=http://localhost:8000
